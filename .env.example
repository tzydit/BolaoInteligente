# Firebase Web SDK (frontend) — pegue em: Console Firebase > Config do Projeto > Seus Apps > SDK Config
VITE_FIREBASE_API_KEY=sua-api-key
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-projeto-id
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Firebase Admin SDK (backend/Vercel) — pegue em: Console Firebase > Config do Projeto > Contas de Serviço > Gerar nova chave privada
FIREBASE_PROJECT_ID=seu-projeto-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@seu-projeto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Cakto Webhook Secret (opcional, pra segurança)
CAKTO_WEBHOOK_SECRET=sua-chave-secreta
